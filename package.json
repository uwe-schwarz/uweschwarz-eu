{
  "name": "uweschwarz-eu",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --bun next dev",
    "build": "bun run --bun next build",
    "deps:visual": "bun ./scripts/deps-visual-check.mjs",
    "deps:visual:preview": "bun run --bun next start --hostname 127.0.0.1 --port 3301",
    "deps:visual:install-browser": "playwright install chromium",
    "start": "next start",
    "lint": "oxlint --deny-warnings --type-aware",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "typecheck": "tsc --noEmit",
    "generate:sitemap": "bun scripts/generate-sitemap.ts",
    "generate:llms": "bun scripts/generate-llms.ts",
    "generate:cv": "bun scripts/generate-cv-assets.ts && bun scripts/generate-sitemap.ts",
    "doctor": "react-doctor --scope changed --base main --no-score --blocking warning",
    "doctor:full": "react-doctor --scope full --blocking warning",
    "update:umami": "bun scripts/update-umami-tracker.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.17",
    "@radix-ui/react-toast": "^1.2.19",
    "@radix-ui/react-tooltip": "^1.2.12",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.10",
    "@react-pdf/renderer": "^4.5.1",
    "@tanstack/react-query": "^5.101.2",
    "@vercel/analytics": "^2.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "docx": "^9.7.1",
    "embla-carousel-react": "^8.6.0",
    "geist": "^1.7.2",
    "lucide-react": "^1.23.0",
    "motion": "^12.42.2",
    "next": "^16.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.81.0",
    "react-icons": "^5.7.0",
    "resend": "^6.17.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "three": "^0.185.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nkzw/oxlint-config": "^1.2.1",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/three": "^0.185.0",
    "autoprefixer": "^10.5.2",
    "eslint-plugin-no-only-tests": "^3.4.0",
    "eslint-plugin-perfectionist": "^5.9.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "husky": "^9.1.7",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "oxlint-tsgolint": "^0.24.0",
    "pixelmatch": "^7.2.0",
    "playwright": "^1.61.1",
    "pngjs": "^7.0.0",
    "postcss": "^8.5.16",
    "react-doctor": "^0.7.1",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "postcss": "8.5.16"
  },
  "trustedDependencies": [
    "@swc/core",
    "esbuild",
    "sharp"
  ]
}
